# =============================================================================
# IOC-Hunter - Configuration des clés API
# =============================================================================
# Copiez ce fichier en .env et remplissez vos clés.
# Chargement : export $(cat .env | xargs)
#
# Les modules WHOIS et DNS fonctionnent SANS clé API.
# Les modules ci-dessous nécessitent une inscription gratuite.
# =============================================================================

# VirusTotal - https://www.virustotal.com/gui/join-us
# Clé gratuite : 4 requêtes/minute, 500/jour
VT_API_KEY=

# AbuseIPDB - https://www.abuseipdb.com/register
# Clé gratuite : 1000 requêtes/jour
ABUSEIPDB_API_KEY=

# Shodan - https://account.shodan.io/register
# Clé gratuite : requêtes limitées (API host lookup)
SHODAN_API_KEY=

# IPInfo - https://ipinfo.io/signup
# Token gratuit : 50000 requêtes/mois
IPINFO_TOKEN=
